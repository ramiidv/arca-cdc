{
  "name": "@ramiidv/arca-cdc",
  "version": "0.1.0",
  "description": "SDK para el web service WSCDC de ARCA (ex AFIP) - Constatacion de Comprobantes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "llms.txt",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "arca",
    "afip",
    "cdc",
    "wscdc",
    "constatacion",
    "comprobantes",
    "argentina",
    "sdk",
    "typescript",
    "cae",
    "cai",
    "caea",
    "factura",
    "invoice",
    "verification"
  ],
  "author": "ramiidv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiidv/arca-cdc.git"
  },
  "homepage": "https://arca-sdk.dev/cdc",
  "bugs": {
    "url": "https://github.com/ramiidv/arca-cdc/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ramiidv/arca-common": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
